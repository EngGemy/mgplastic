                  "if (token) pm.collectionVariables.set('store_token', token);",
                  "pm.test('store login', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{store_phone}}\",\n  \"password\": \"{{store_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            }
          }
        }
      ]
