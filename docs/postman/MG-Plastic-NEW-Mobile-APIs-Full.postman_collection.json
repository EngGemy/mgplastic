{
  "info": {
    "name": "MG Plastic — NEW Mobile APIs (Full)",
    "_postman_id": "f0a1b2c3-newapi-4000-9000-mgnewfull",
    "description": "# كل الـ Endpoints الجديدة — للاستخدام المباشر\n\nBase: `{{base_url}}/api/v1`\n\n## الأقسام\n1. Auth\n2. Plumber → طلب محل تجزئة + منتجات + محفظة convert\n3. Trader → منتجات + طلبيات جملة + تنفيذ طلبات السباكين\n4. Notifications (سباك / تاجر)\n\nAuth: Bearer token حسب الدور.\n\n## ملفات منفصلة (تفصيل أكثر)\n- `MG-Plastic-Plumber-Orders-to-Retail.postman_collection.json`\n- `MG-Plastic-Trader-Orders.postman_collection.json`\n- `MG-Plastic-Notifications.postman_collection.json`\n- `MG-Plastic-Points-Convert-Withdraw.postman_collection.json`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://mg-plastic.com", "type": "string" },
    { "key": "plumber_phone", "value": "", "type": "string" },
    { "key": "plumber_password", "value": "", "type": "string" },
    { "key": "plumber_token", "value": "", "type": "string" },
    { "key": "trader_phone", "value": "", "type": "string" },
    { "key": "trader_password", "value": "", "type": "string" },
    { "key": "trader_token", "value": "", "type": "string" },
    { "key": "retail_trader_id", "value": "", "type": "string" },
    { "key": "product_id", "value": "1", "type": "string" },
    { "key": "order_id", "value": "", "type": "string" },
    { "key": "plumber_order_id", "value": "", "type": "string" },
    { "key": "trader_order_id", "value": "", "type": "string" },
    { "key": "notification_id", "value": "", "type": "string" },
    { "key": "points_to_convert", "value": "100", "type": "string" },
    { "key": "per_page", "value": "20", "type": "string" },
    { "key": "page", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "0 — Auth",
      "item": [
        {
          "name": "Login Plumber",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "const token = json?.data?.token || json?.token;",
                "if (token) pm.collectionVariables.set('plumber_token', token);",
                "pm.test('login plumber', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{plumber_phone}}\",\n  \"password\": \"{{plumber_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        },
        {
          "name": "Login Retail Trader",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "const token = json?.data?.token || json?.token;",
                "if (token) pm.collectionVariables.set('trader_token', token);",
                "const id = json?.data?.user?.id || json?.data?.store?.id;",
                "if (id) pm.collectionVariables.set('retail_trader_id', String(id));",
                "pm.test('login trader', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{trader_phone}}\",\n  \"password\": \"{{trader_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "1 — Plumber: Products (كل منتجات MG)",
      "item": [
        {
          "name": "GET products (paginated)",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "const first = json?.data?.items?.[0];",
                "if (first?.id) pm.collectionVariables.set('product_id', String(first.id));",
                "console.log('total=', json?.data?.pagination?.total);"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Accept-Language", "value": "ar" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/products?per_page={{per_page}}&page={{page}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "products"],
              "query": [
                { "key": "per_page", "value": "{{per_page}}" },
                { "key": "page", "value": "{{page}}" },
                { "key": "q", "value": "", "disabled": true },
                { "key": "category_id", "value": "", "disabled": true },
                { "key": "has_points", "value": "", "disabled": true, "description": "1=with points | 0=without | empty=all" }
              ]
            },
            "description": "## GET `/api/v1/mobile/plumber/products`\n\nيرجع **كل** منتجات MG (حتى بدون نقاط).\n\nResponse item: `id, name, description, image_url, points_per_unit, has_points, category_id, category_name` + `pagination`"
          }
        },
        {
          "name": "Search products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/products?q=ترهونه&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "products"],
              "query": [
                { "key": "q", "value": "ترهونه" },
                { "key": "per_page", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2 — Plumber: Orders → Retail store",
      "description": "السباك يطلب أي منتج من محل التجزئة — بدون فحص مخزون عند الإنشاء.\nchannel = `retail_to_plumber`",
      "item": [
        {
          "name": "POST place order",
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const json = pm.response.json();",
                "if (json?.data?.id) {",
                "  pm.collectionVariables.set('plumber_order_id', String(json.data.id));",
                "  pm.collectionVariables.set('order_id', String(json.data.id));",
                "}",
                "pm.test('order placed', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"retail_trader_id\": {{retail_trader_id}},\n  \"lines\": [\n    { \"product_id\": {{product_id}}, \"quantity\": 2 }\n  ],\n  \"note\": \"طلب من السباك لمحل التجزئة\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "orders"]
            },
            "description": "## POST `/api/v1/mobile/plumber/orders`\n\n| field | required |\n|-------|----------|\n| retail_trader_id | ✅ user id للتاجر القطاعي |\n| lines[].product_id | ✅ |\n| lines[].quantity | ✅ ≥1 |\n| note | ❌ |\n\nStatus بعد الإنشاء: `placed` (بانتظار التأكيد)\nالمخزون **لا يُفحص** هنا."
          }
        },
        {
          "name": "GET list my orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/orders",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "orders"],
              "query": [
                { "key": "status", "value": "", "disabled": true, "description": "placed|confirmed|shipping|delivered|cancelled|rejected" }
              ]
            }
          }
        },
        {
          "name": "GET show order",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/orders/{{plumber_order_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "orders", "{{plumber_order_id}}"]
            }
          }
        },
        {
          "name": "POST receive (after ship)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/orders/{{plumber_order_id}}/receive",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "orders", "{{plumber_order_id}}", "receive"]
            },
            "description": "بعد ما التاجر يعمل ship — الاستلام يمنح النقاط لمحفظة السباك من مخزون القطاعي."
          }
        },
        {
          "name": "POST cancel",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{plumber_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"لم أعد أحتاج الطلب\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/mobile/plumber/orders/{{plumber_order_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "mobile", "plumber", "orders", "{{plumber_order_id}}", "cancel"]
            }
          }
        }
      ]
    },
