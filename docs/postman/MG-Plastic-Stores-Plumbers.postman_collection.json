                { "key": "video_url", "value": "https://youtu.be/xxxx", "type": "text" },
                { "key": "website", "value": "https://my-plumber.ly", "type": "text" },
                { "key": "address", "value": "طرابلس - حي الأندلس", "type": "text" },
