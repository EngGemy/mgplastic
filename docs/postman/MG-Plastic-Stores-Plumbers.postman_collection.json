    {
      "name": "Orders — Distributor (موزع الجملة)",
      "description": "Wholesale distributor: place orders to the factory + fulfil orders from its retail traders. Login as a wholesale_distributor first (token saved).",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [ { "key": "Accept", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/api/v1/mobile/distributor/orders?scope=", "host": ["{{base_url}}"], "path": ["api","v1","mobile","distributor","orders"], "query": [ { "key": "scope", "value": "", "description": "empty=all | placed=my orders to factory | incoming=orders from my retail traders" }, { "key": "status", "value": "", "disabled": true } ] },
            "description": "All orders where I am buyer or supplier."
          }
        },
        {
          "name": "Place Order to Factory",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) { pm.collectionVariables.set('order_id', json.data.id); }",
